# =============================================
# VWorks Technologies — Environment Variables
# Vercel Dashboard > Settings > Environment Variables 에 동일하게 입력
# =============================================

# SMTP 이메일 설정 (필수)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=aiden@vworks.tech
SMTP_PASS=your-app-password-here

# 이메일 주소
MAIL_FROM=noreply@vworks.tech
MAIL_TO=aiden@vworks.tech

# 사이트 URL
NEXT_PUBLIC_SITE_URL=https://vworks.tech

# Google Analytics (선택)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
